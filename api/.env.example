# Server
PORT=3333

# Database (used by Prisma)
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@HOST:PORT/POSTGRES_DB
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Docker Compose (local only — not needed in production)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# OpenAI
OPENAI_API_KEY=
